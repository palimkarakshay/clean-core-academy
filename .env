# Clean Core Academy — committed defaults for the learning-app shell.
# NEXT_PUBLIC_* values are inlined into the client bundle at build time.

# Active content pack. The @active-pack alias (next.config.ts /
# vitest.config.ts) resolves to content-packs/<this id>/.
NEXT_PUBLIC_CONTENT_PACK_ID=clean-core-academy

# The Adept (designer-lane / SME-workbench / /for-teams) surface ships
# with the shell but is irrelevant to a single-course academy. Disabling
# it hides the designer lane on the home page and 404s /adept + /for-teams
# (see src/middleware.ts + src/lib/feature-flags.ts).
NEXT_PUBLIC_ADEPT_ENABLED=0
NEXT_PUBLIC_AI_DECODER_ENABLED=0
