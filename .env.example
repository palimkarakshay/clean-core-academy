# =====================================================================
# .env.example — every variable the web app reads.
#
# Copy to `.env.local` (gitignored) and fill in. Public values
# (NEXT_PUBLIC_*) are inlined into the client bundle at build time;
# everything else is server-only.
#
# Adding a new variable? Document it here in the same block as the
# code that reads it, so contributors can grep both directions.
# =====================================================================


# ---------------------------------------------------------------------
# Content pack selection (used today)
# ---------------------------------------------------------------------
# Selects the active content pack at build time. The webpack alias
# `@active-pack` resolves to `content-packs/<id>/`, so tree-shaking
# drops the inactive packs from the bundle.
#
# Read by: next.config.ts, src/content/active-pack.ts
# Default: cca-f-prep
NEXT_PUBLIC_CONTENT_PACK_ID=cca-f-prep


# ---------------------------------------------------------------------
# Feature flags (used today)
# ---------------------------------------------------------------------
# Adept (designer lane) + SME workbench + /for-teams marketing surface.
# Per v2-scaled-b2b-plan.md these are deferred to Phase 2; the code
# exists but is hidden until this flag is set to "1".
#
# Read by: middleware.ts (route gate), components that link into Adept
NEXT_PUBLIC_ADEPT_ENABLED=0

# AI-backed journey decoder. When unset/0, the local regex heuristic
# in src/lib/journey-decoder.ts runs (free, deterministic, offline).
# When set to 1, the decoder calls lib/ai/router.ts (real money).
#
# Read by: components/dashboard/LearningGoalCapture.tsx,
#          components/dashboard/DesignerJourneyDecoder.tsx
NEXT_PUBLIC_AI_DECODER_ENABLED=0


# ---------------------------------------------------------------------
# LLM router (scaffolded, not yet wired)
# ---------------------------------------------------------------------
# Per plans/v2-scaled-b2b-plan.md §9: ALL LLM calls go through
# src/lib/ai/router.ts. No SDK imports outside that file. OpenRouter
# is the API surface; Anthropic models are addressed via OpenRouter
# slugs (e.g. anthropic/claude-haiku-4.5).
#
# Server-only. Never expose with NEXT_PUBLIC_.
OPENROUTER_API_KEY=

# Optional override of the default model slug. If unset, the router
# uses anthropic/claude-haiku-4.5 (cheap drafter per v2 §9).
AI_DEFAULT_MODEL=anthropic/claude-haiku-4.5


# ---------------------------------------------------------------------
# Auth + DB (Phase 1, weeks 1-2 per v2 §6 — not yet wired)
# ---------------------------------------------------------------------
# Clerk personal accounts in v1; Organizations enabled in week 7-8.
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Neon Postgres (free tier in v1 → Scale at 100 paid users / 250 MB).
DATABASE_URL=


# ---------------------------------------------------------------------
# Observability (scaffolded, optional)
# ---------------------------------------------------------------------
# Sentry. If DSN is empty, the SDK no-ops — safe to leave blank in dev.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development


# ---------------------------------------------------------------------
# Secrets policy
# ---------------------------------------------------------------------
# - `.env.local` is gitignored — never commit it.
# - `NEXT_PUBLIC_*` values are SHIPPED TO THE BROWSER. Use only for
#   public configuration (pack id, feature flags, publishable keys).
# - Server-side secrets (OPENROUTER_API_KEY, CLERK_SECRET_KEY,
#   DATABASE_URL) must be set in Vercel project env, not in code.
# - Rotate any secret that has ever appeared in a commit or a CI log.
# - Run `git secrets --scan` (or equivalent) before pushing if you
#   suspect a paste-error; CI's codex-review workflow will flag obvious
#   leaks but is not a replacement for hygiene.
# ---------------------------------------------------------------------
