# =====================================================================
# .env.example — environment variables the app actually reads.
#
# Copy to `.env.local` (gitignored) and fill in. Public values
# (NEXT_PUBLIC_*) are inlined into the client bundle at build time;
# everything else is server-only. If you add a variable, document it
# here in the same block as the code that reads it.
# =====================================================================


# ---------------------------------------------------------------------
# Content pack selection (used today)
# ---------------------------------------------------------------------
# Selects the active content pack at build time. The `@active-pack`
# alias resolves to `content-packs/<id>/`, so tree-shaking drops the
# inactive packs from the bundle.
#
# Read by: next.config.ts, src/content/active-pack.ts
# Default: clean-core-academy (the only pack this repo ships). A value
# pointing at a missing pack folder falls back to clean-core-academy.
NEXT_PUBLIC_CONTENT_PACK_ID=clean-core-academy


# ---------------------------------------------------------------------
# LLM router (optional)
# ---------------------------------------------------------------------
# All LLM calls go through src/lib/ai/router.ts, which talks to the
# Vercel AI Gateway via the AI SDK (`generateText`). Models are bare
# "provider/model" gateway slugs (e.g. anthropic/claude-haiku-4.5).
#
# Auth: set AI_GATEWAY_API_KEY locally; on Vercel a deployment OIDC
# token (VERCEL_OIDC_TOKEN) is auto-injected and used as the keyless
# fallback. With NEITHER present, generate() returns "not-configured"
# before any network call (the "AI off = no spend" guarantee) and the
# app runs fully without it.
#
# Server-only. Never expose with NEXT_PUBLIC_.
# Read by: src/lib/ai/router.ts
AI_GATEWAY_API_KEY=

# Optional override of the default model slug. If unset, the router
# uses anthropic/claude-haiku-4.5.
# Read by: src/lib/ai/router.ts
AI_DEFAULT_MODEL=anthropic/claude-haiku-4.5

# Cost defenses (src/lib/ai/cost-controls.ts). In-process per-instance;
# set to 0 to disable a guard. A true cross-instance limiter needs a
# shared store (Vercel KV / Upstash) — see the module header.
# Read by: src/lib/ai/cost-controls.ts
AI_RATE_LIMIT_PER_MIN=20
AI_TOKEN_BUDGET_PER_DAY=200000
# Process-wide ceilings — backstop that bounds total spend even if a caller
# cycles tenant identities to evade the per-tenant caps above.
AI_GLOBAL_RATE_LIMIT_PER_MIN=120
AI_GLOBAL_TOKEN_BUDGET_PER_DAY=1000000


# ---------------------------------------------------------------------
# Secrets policy
# ---------------------------------------------------------------------
# - `.env.local` is gitignored — never commit a real secret.
# - `NEXT_PUBLIC_*` values are SHIPPED TO THE BROWSER. Use only for
#   public configuration (e.g. the pack id).
# - Server-side secrets (AI_GATEWAY_API_KEY) belong in the Vercel
#   project env, not in code.
# - Rotate any secret that has ever appeared in a commit or a CI log.
# ---------------------------------------------------------------------
