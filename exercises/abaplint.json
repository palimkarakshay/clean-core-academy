{
  "global": {
    "files": "/src/**/*.*",
    "skipGeneratedGatewayClasses": true,
    "skipGeneratedPersistentClasses": true,
    "skipGeneratedFunctionGroups": true
  },
  "dependencies": [],
  "syntax": {
    "version": "v755",
    "errorNamespace": "^(Z|Y|LCL_|TY_|LIF_)",
    "globalConstants": [],
    "globalMacros": []
  },
  "rules": {
    "parser_error": true,
    "unknown_types": false,
    "check_syntax": false,
    "7bit_ascii": true,
    "avoid_use": {
      "define": true,
      "endselect": true,
      "execSQL": true,
      "kernelCall": true,
      "communication": true,
      "statics": false,
      "defaultKey": false
    },
    "colon_missing_space": true,
    "contains_tab": true,
    "definitions_top": false,
    "empty_statement": true,
    "exit_or_check": true,
    "functional_writing": true,
    "identical_conditions": true,
    "in_statement_indentation": true,
    "indentation": {
      "ignoreExceptions": false,
      "alignTryCatch": false,
      "globalClassSkipFirst": false
    },
    "keyword_case": {
      "style": "lower",
      "ignoreExceptions": true,
      "ignoreLowerClassImplmentationStatement": true,
      "ignoreGlobalClassDefinition": false,
      "ignoreGlobalInterface": false
    },
    "line_length": {
      "length": 120
    },
    "max_one_statement": true,
    "method_length": {
      "statements": 120
    },
    "no_public_attributes": {
      "allowReadOnly": true,
      "ignoreTestClasses": true
    },
    "object_naming": {
      "clas": "^ZC(L|X)_AU(_|$)",
      "intf": "^ZIF_AU(_|$)"
    },
    "sequential_blank": {
      "lines": 3
    },
    "space_before_colon": true,
    "space_before_dot": true,
    "start_at_tab": true,
    "tabl_enhancement_category": false,
    "whitespace_end": true
  }
}
